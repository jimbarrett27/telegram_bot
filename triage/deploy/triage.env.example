# Production environment for the triage backend.
# Copy to /etc/triage.env (referenced by triage-backend.service) and fill in.

# Enforce the Cloudflare Access identity header as defence in depth.
TRIAGE_REQUIRE_CF_ACCESS=true

# The single permitted Google identity (must match the Access policy).
TRIAGE_ALLOWED_EMAIL=jimbarrett27@gmail.com

# The website origin the SPA is served from (for CORS). No trailing slash.
# The SPA and API share the apex domain but are cross-origin (different host).
TRIAGE_ALLOWED_ORIGINS=https://jimbarrett.dev

# Bind localhost only; the Cloudflare Tunnel is the sole ingress.
TRIAGE_HOST=127.0.0.1
TRIAGE_PORT=8077

# Obsidian vault on jim-server (synced via the obsidian-sync service) and the
# vault-relative folder stubs are written into.
TRIAGE_OBSIDIAN_VAULT=/mnt/storage/data/obsidian
TRIAGE_OBSIDIAN_INBOX_SUBDIR=Papers

# Push `deep` papers to Zotero. The user ID and API key are NOT set here: both
# are fetched from GCP Secret Manager (secrets `ZOTERO_USER_ID` and
# `ZOTERO_API_KEY` in project personal-website-318015), so the service needs
# Application Default Credentials available — same as the Telegram bot (jim's
# gcloud ADC under $HOME/.config/gcloud, which systemd exposes via HOME for
# User=jim). Set this to `true` to enable; leave empty/false to disable (dev).
TRIAGE_ZOTERO_ENABLED=false
